# ─── Supabase ───────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key (safe for frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ─── App URL ────────────────────────────────────────────────
# Production URL — used as Google OAuth callback base
# Must match the authorized redirect URI in Google Cloud Console
APP_URL=https://elektro.gradevinskidnevnik.online

# ─── Google OAuth (Calendar integration) ────────────────────
# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Gemini AI (diary summaries) ────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Resend (email invitations) ─────────────────────────────
# Optional — invitations skip email silently if not set
RESEND_API_KEY=re_your-api-key
# Optional — defaults to noreply@gradevinski-dnevnik.com
# RESEND_FROM=Gradevinski Dnevnik <noreply@yourdomain.com>

# ─── Notifications ───────────────────────────────────────────
# Email address to receive waitlist signup notifications
NOTIFY_EMAIL=your-email@example.com

# ─── Runtime ────────────────────────────────────────────────
NODE_ENV=production
# PORT is typically injected by the hosting platform automatically
# PORT=8080
